# Minecraft サーバーのホスト名
HOST=donutsmp.net

# Minecraft サーバーのポート番号
PORT=25565

# BotのMicrosoftアカウントのメールアドレス（任意 — 未設定の場合は Web UI でログイン）
# BOT_USERNAME=your_email@example.com

# Botのパスワード（省略可）
# 設定するとデバイスコード入力なしで自動ログインできます
# ※ 2要素認証が有効なアカウントでは使用できません
# BOT_PASSWORD=your_password

# 認証方式: microsoft または offline
AUTH=microsoft

# Minecraft バージョン
VERSION=1.21.1

# Bot WebSocket サーバーのポート番号
WEB_PORT=3000

# Bot視点 Viewer サーバーのポート番号
BOT_VIEWER_PORT=3002

# Bot視点 Viewer のURLプレフィックス
BOT_VIEWER_PREFIX=/viewer

# Bot視点 Viewer の描画距離（重い場合は下げる）
BOT_VIEWER_VIEW_DISTANCE=6

# Bot視点 Viewer を有効化するか（Termux など canvas 導入が難しい環境では false 推奨）
BOT_VIEWER_ENABLED=true

# Web UI (Next.js) から Bot WebSocket に接続するURL
# 省略時は自動的に ws://<hostname>:3000 が使われます
# NEXT_PUBLIC_WS_URL=ws://localhost:3000

# Web UI に埋め込む Bot視点 Viewer のURL
# 省略時は自動的に <現在のページのプロトコル>://<hostname>:3002/viewer/ が使われます
# NEXT_PUBLIC_BOT_VIEWER_URL=http://localhost:3002/viewer/
