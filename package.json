{
  "name": "donutsmp-bot",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/**/*.test.js",
    "test:ci": "pnpm build && pnpm test",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:all": "concurrently --names \"web,bot\" --prefix-colors \"cyan,yellow\" \"pnpm --filter donutsmp-bot-web dev\" \"pnpm dev\"",
    "web:dev": "pnpm --filter donutsmp-bot-web dev",
    "web:build": "pnpm --filter donutsmp-bot-web build",
    "web:start": "pnpm --filter donutsmp-bot-web start",
    "viewer-three:dev": "pnpm --filter viewer-via-three dev",
    "viewer-three:build": "pnpm --filter viewer-via-three build",
    "viewer-three:preview": "pnpm --filter viewer-via-three preview"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "mineflayer": "^4.37.0",
    "prismarine-viewer": "^1.33.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
